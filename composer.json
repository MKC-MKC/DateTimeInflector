{
    "license": "MIT",
    "minimum-stability": "stable",
    "name": "haikiri/datetime-inflector",
    "description": "DateTimeInflector - Эта библиотека работает со склонением времени.",
    "keywords": [
        "php",
        "sdk",
        "datetime",
        "Inflector"
    ],
    "homepage": "https://github.com/MKC-MKC/DateTimeInflector",
    "type": "library",
    "require": {
        "php": ">=8.0",
        "haikiri/declension-helper": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Haikiri\\DatetimeInflector\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\DatetimeInflector\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Haikiri",
            "email": "haikiri@ya.ru",
            "homepage": "https://haikiri.t.me"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "scripts": {
        "test": "vendor/bin/phpunit --colors=always tests",
        "test:debug": "vendor/bin/phpunit --colors=always --debug tests",
        "test:dox": "vendor/bin/phpunit --colors=always --testdox tests"
    }
}
